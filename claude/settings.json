{
  "statusLine": {
    "type": "command",
    "command": "cship"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh stop"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh permission"
          }
        ]
      }
    ]
  }
}
